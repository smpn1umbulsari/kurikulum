# =============================================================================
# GURU SPENTURI v2 - Environment Variables Template
# =============================================================================
# Copy file ini ke .env.local dan isi dengan nilai yang sesuai.
# JANGAN commit file .env.local ke git repository!
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE CONFIGURATION
# -----------------------------------------------------------------------------

# URL dari Supabase project Anda
# Format: https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Anonymous/Public key dari Supabase (aman untuk client-side)
# Key ini dapat dilihat di: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role Key (RAHASIA - HANYA untuk server-side, BUKAN untuk client)
# Key ini dapat bypass RLS, JANGAN export ke client-side code
# Key ini dapat dilihat di: Supabase Dashboard > Project Settings > API
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -----------------------------------------------------------------------------
# APPLICATION CONFIGURATION
# -----------------------------------------------------------------------------

# URL aplikasi (untuk redirect dan absolute URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Environment: development | staging | production
NODE_ENV=development

# -----------------------------------------------------------------------------
# OPTIONAL: ANALYTICS & MONITORING
# -----------------------------------------------------------------------------

# Sentry DSN untuk error tracking (opsional, akan ditambahkan di Sprint 3)
# NEXT_PUBLIC_SENTRY_DSN=https://example@o123456.ingest.sentry.io/1234567

# -----------------------------------------------------------------------------
# CATEGORIES:
# -----------------------------------------------------------------------------
# 
# 1. SUPABASE CONFIGURATION (WAJIB)
#    - NEXT_PUBLIC_SUPABASE_URL
#    - NEXT_PUBLIC_SUPABASE_ANON_KEY
#    - SUPABASE_SERVICE_ROLE_KEY
#
# 2. APPLICATION CONFIG (WAJIB)
#    - NEXT_PUBLIC_APP_URL
#
# 3. OPTIONAL (DITAMBAHKAN NANTI)
#    - Analytics keys
#    - Payment gateway (jika ada)
#    - Email service (jika ada)
# -----------------------------------------------------------------------------