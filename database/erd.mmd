    }

    KARTU_PENGAWAS {
        uuid id PK
        uuid asesmen_id FK
        uuid guru_id FK
        timestamptz published_at
    }

    KETERSEDIAAN_PENGAWAS {
        uuid id PK
        uuid guru_id FK
        uuid semester_id FK
        varchar hari
        time jam_mulai
        time jam_selesai
