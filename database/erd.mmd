        text keterangan
    }

    %% ============================================================
    %% SISTEM & BACKUP
    %% ============================================================
    AUDIT_LOG {
        uuid id PK
        uuid pengguna_id FK
        text aksi
        text tabel
        uuid record_id
        jsonb data_sebelum
        jsonb data_sesudah
    }

    BACKUP_LOG {
        uuid id PK
        text backup_type
        varchar file_name
        bigint file_size
        text status
        text error_message
        timestamptz started_at
        timestamptz completed_at
        uuid performed_by FK
    }

    RESTORE_LOG {
        uuid id PK
        varchar backup_file
        text status
        integer tables_restored
        bigint records_restored
        text error_message
        timestamptz started_at
        timestamptz completed_at
        uuid performed_by FK
        uuid confirmed_by FK
        text confirmation_note
    }

    IMPORT_TEMPLATE_LOG {
        uuid id PK
        uuid semester_id FK
        uuid kelas_real_id FK
        uuid mata_pelajaran_id FK
        timestamptz generated_at
        text storage_path
    }

    %% ============================================================
    %% VALIDASI DATA
    %% ============================================================
    VALIDATION_RULE {
        uuid id PK
        varchar rule_name
        varchar table_name
        varchar field_name
        text rule_type
        jsonb rule_config
        text error_message
        text severity
        boolean is_active
    }

    VALIDATION_RESULT {
        uuid id PK
        uuid rule_id FK
        uuid record_id
        uuid semester_id FK
        text error_detail
        boolean is_resolved
        timestamptz resolved_at
        uuid resolved_by FK
    }

    %% ============================================================
    %% PENGATURAN & NOTIFIKASI
    %% ============================================================
    SYSTEM_SETTINGS {
        uuid id PK
        varchar setting_key
        text setting_value
        text setting_type
        text description
        uuid updated_by FK
        timestamptz updated_at
    }

    PENGATURAN_SEKOLAH {
        uuid id PK
        text nama_sekolah
        text alamat
        text logo_url
        text template_rapor_url
        enum mode_ttd_kepsek
        boolean mode_pemeliharaan
    }

    NOTIFICATION {
        uuid id PK
        uuid user_id FK
        varchar title
        text message
        text type
        boolean is_read
        text link
    }

